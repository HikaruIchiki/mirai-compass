    document.getElementById('runInsuranceBtn').addEventListener('click', () => {
        if (!lastSimulation) return;
        
        document.getElementById('insuranceIntroModal').classList.remove('show');
        const btn = document.getElementById('runInsuranceBtn');
        btn.disabled = true;
        btn.textContent = '分析中...';
        
        setTimeout(() => {
            const survivorRatio = toNumber(document.getElementById('survivorRatioInput').value, 70) / 100;
            const pensionTerm = toNumber(document.getElementById('pensionTermInput').value, 10);
            const params = buildParamsFromForm(document.getElementById('lifePlanForm'));
            const sim = lastSimulation;
            const selfAge = sim.meta.selfAge;
            const includeAssets = document.getElementById('includeAssetsInInsuranceCalc').checked;
            const chartLabels = []; const chartData = [];
            let maxShortfall = -1; let maxRiskAge = selfAge;
            
            for(let deathAge = selfAge; deathAge <= params.retireAge; deathAge++) {
                const deathYearIndex = deathAge - selfAge;
                if (deathYearIndex < 0 || deathYearIndex >= sim.years) continue;
                let cumulativeShortfall = 0;
                let currentAssets = 0;
                if(includeAssets){
                    currentAssets = (sim.cashHistory[deathYearIndex] || 0) + (sim.investHistory[deathYearIndex] || 0);
                }
                let youngestChildIndependenceYearIndex = sim.years;
                if(params.family.children && params.family.children.length > 0){
                    const youngestChild = params.family.children.reduce((prev, curr) => (prev.age < curr.age) ? prev : curr);
                    const independenceAge = 22;
                    youngestChildIndependenceYearIndex = (independenceAge - youngestChild.age);
                }
                const endLoopYear = Math.min(sim.years, deathYearIndex + youngestChildIndependenceYearIndex);
                for (let i = deathYearIndex + 1; i < endLoopYear; i++) {
                    const survivorsPension = calculateSurvivorsPension(params, deathAge, pensionTerm, i);
                    const income = (sim.salarySpouse[i]||0) + (sim.bonusSpouse[i]||0) + sim.childBenefitData[i] + survivorsPension;
                    const outflow = sim.livingData[i] * survivorRatio + sim.housingData[i] + sim.educationData[i] + sim.planData[i] + sim.taxData[i] + sim.socialSalaryData[i] + sim.pensionSocialData[i] + sim.savingData[i];
                    const net = income - outflow;
                    currentAssets += net;
                    if (currentAssets < 0) {
                        cumulativeShortfall += Math.abs(currentAssets);
                        currentAssets = 0;
                    }
                }
                chartLabels.push(`${deathAge}歳`);
                chartData.push(cumulativeShortfall);
                if(cumulativeShortfall > maxShortfall) {
                    maxShortfall = cumulativeShortfall;
                    maxRiskAge = deathAge;
                }
            }
            const resultDiv = document.getElementById('insuranceResult');
            const assetNote = includeAssets
                ? "<strong>計算にはその時点での資産残高（現預金・金融資産）を<span style='color:green;'>含めて</span>います。</strong>"
                : "<strong>計算にはその時点での資産残高を<span style='color:red;'>含めていません</span>（資産ゼロを仮定）。</strong>";
            resultDiv.innerHTML = `
                <h3>年齢別の必要保障額リスク</h3>
                <p>${assetNote}<br>遺族の生活費を${survivorRatio*100}%、遺族年金（概算）を考慮して計算。死亡退職金は考慮されていません。あくまで簡易的な目安です。</p>
                <p style="font-size:1.1rem; font-weight:bold;">
                    ⚠️ <span style="color:#ef4444;">${maxRiskAge}歳</span>で万一の事態が発生した場合に、必要保障額が最大（<span style="color:#ef4444;">${formatAmount(maxShortfall)}万円</span>）となります。
                </p>
            `;

            const insuranceData = { term: [], income: [], whole: [] };
            if (maxShortfall > 0) {
                const termEndAge = maxRiskAge + 20;
                const incomeEndAge = 65;
                
                chartLabels.forEach(ageStr => {
                    const age = parseInt(ageStr, 10);
                    insuranceData.term.push(age >= maxRiskAge && age <= termEndAge ? maxShortfall : null);
                    insuranceData.whole.push(age >= maxRiskAge ? maxShortfall : null);
                    if (age >= maxRiskAge && age <= incomeEndAge) {
                        const progress = (age - maxRiskAge) / (incomeEndAge - maxRiskAge);
                        insuranceData.income.push(maxShortfall * (1 - progress));
                    } else {
                        insuranceData.income.push(null);
                    }
                });
            }

            if (chartLabels.length > 0) {
              renderInsuranceChart(chartLabels, chartData, insuranceData);
            }
            document.getElementById('insuranceModal').classList.add('show');
            btn.disabled = false;
            btn.textContent = '▶ 年齢別リスクを計算';
        }, 10);
    });

