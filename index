      const hasValidSpouseAge = Number.isFinite(spouseAgeVal) && spouseAgeVal > 0;
      const spouseAgeBase = hasValidSpouseAge ? spouseAgeVal : NaN;
      const years = 100 - selfAge + 1;
      const labels = [];
      const salarySelf = []; const salarySpouse = []; const bonusSelf = []; const bonusSpouse = []; const pensionSelf = []; const pensionSpouse = []; const otherIncome = [];
      const assetTakeouts = Array(years).fill(0);
      const notifications = []; const savingData = []; const withdrawData = [];
      const infl = inflationPct / 100;
      const gSelf = incomeGrowthPct / 100;

      const dcData = [];
      const dcAnnualIndivCost = (dcConfig.indiv / 10000) * 12 || 0;
      const dcAnnualCorpContrib = (dcConfig.corp / 10000) * 12 || 0;
      const dcRate = (dcConfig.rate || 3) / 100;
      let dcBalance = dcConfig.initial || 0;

      for (let i=0;i<years;i++){
        const age = selfAge + i; labels.push(`${age}歳`);
        const base = age <= retireAge ? Math.floor(incomeStart * Math.pow(1 + gSelf, i)) : 0;
        salarySelf.push(age <= retireAge ? base : 0);
        bonusSelf.push(age === retireAge ? retirementBonus : 0);
        pensionSelf.push(0); pensionSpouse.push(0); otherIncome.push(0);
      }
      if (Array.isArray(customIncomeSelf) && customIncomeSelf.length){
        const map = new Map(customIncomeSelf.map(e => [e.age, e.salary]));
        for (let i=0;i<years;i++){ const age = selfAge + i; if (map.has(age)) salarySelf[i] = map.get(age); }
      }
      const KOSEI_NENKIN_RATE = 5.481 / 1000;
      const KISO_NENKIN_ANNUAL = 78;
      const selfPensionAnnual = Math.floor(toNumber(pensionConfig?.selfAvgMonthly, 30) * KOSEI_NENKIN_RATE * 480 + KISO_NENKIN_ANNUAL);
      for (let i=0;i<years;i++){ const age=selfAge+i; if (age >= 65) pensionSelf[i]=selfPensionAnnual; }
      const sp = spouseIncomeSettings || {incomeStart:0,incomeGrowthPct:0,retireAge:65,retirementBonus:0};
      const gSp = toNumber(sp.incomeGrowthPct, 0) / 100;
      if (hasValidSpouseAge) {
        for (let i=0;i<years;i++){
          const ageSp = spouseAgeBase + i;
          const spRetireAge = toNumber(sp.retireAge, 65);
          const retired = ageSp > spRetireAge;
          const base = (!retired) ? Math.floor(toNumber(sp.incomeStart,0) * Math.pow(1+gSp, i)) : 0;
          salarySpouse.push(retired ? 0 : base);
          bonusSpouse.push(ageSp === spRetireAge ? toNumber(sp.retirementBonus,0) : 0);
        }
        if (Array.isArray(customIncomeSpouse) && customIncomeSpouse.length){
          const map = new Map(customIncomeSpouse.map(e => [e.age, e.salary]));
          for (let i=0;i<years;i++){ const ageSp = spouseAgeBase + i; if (map.has(ageSp)) salarySpouse[i] = map.get(ageSp); }
        }
        const spousePensionAnnual = Math.floor(toNumber(pensionConfig?.spouseAvgMonthly, 0) * KOSEI_NENKIN_RATE * 480 + KISO_NENKIN_ANNUAL);
        for (let i=0;i<years;i++){ const ageSp = spouseAgeBase+i; if (ageSp >= 65) pensionSpouse[i]=spousePensionAnnual; }
      } else {
        for (let i=0;i<years;i++){ salarySpouse.push(0); bonusSpouse.push(0); }
      }
      let childBenefitNotified = false;
      (family.children || []).forEach(child => {
        for (let i = 0; i < years; i++) {
            const childAge = child.age + i;
            if (childAge >= 0 && childAge < 15) {
                otherIncome[i] += 12;
                if (!childBenefitNotified) {
                    notifications.push({ age: selfAge + i, type: 'success', message: `💡 ${selfAge + i}歳から児童手当（年間12万円）が計上されます。` });
                    childBenefitNotified = true;
                }
            }
        }
      });
      (planConfig || []).forEach(p => {
          if (p.name.includes('出産')) {
              const yearIndex = p.age - selfAge;
              if (yearIndex >= 0 && yearIndex < years) {
                  otherIncome[yearIndex] += 50;
                  notifications.push({ age: p.age, type: 'success', message: `💡 ${p.age}歳に出産一時金（50万円）が計上されます。` });
              }
          }
      });
      const taxData = []; const socialSalaryData = []; const pensionSocialData = []; const totalIncome = [];
      for (let i=0;i<years;i++){
        if(selfAge + i === retireAge) {
          bonusSelf[i] += dcBalance;
          dcBalance = 0;
        }
        const totalPension = pensionSelf[i] + pensionSpouse[i];
        const salBonusSelf = salarySelf[i] + bonusSelf[i];
        const salBonusSp = (salarySpouse[i]||0) + (bonusSpouse[i]||0);
        const { tax: taxSelf, social: socialSelf } = calcSalaryTaxAndSocial(salBonusSelf);
        const { tax: taxSp, social: socialSp } = calcSalaryTaxAndSocial(salBonusSp);
        const { tax: penTax, social: penSocial } = calcPensionTaxAndSocial(totalPension);
        taxData.push(taxSelf + taxSp + penTax);
        socialSalaryData.push(socialSelf + socialSp);
        pensionSocialData.push(penSocial);
        totalIncome.push(salarySelf[i] + (salarySpouse[i]||0) + totalPension + otherIncome[i] + bonusSelf[i] + (bonusSpouse[i]||0));
      }
      const livingData = Array.from({length:years}, (_,i)=> Math.floor(livingMonthly * 12 * Math.pow(1 + infl, i)));
      const housingData = [];
      for (let i=0;i<years;i++){
        const age = selfAge + i; let housing=0;
        (housingConfig||[]).forEach(cfg=>{
          const occ = cfg.occStart!=null && cfg.occEnd!=null ? (age >= cfg.occStart && age <= cfg.occEnd) : false;
          if (cfg.type === 'rent') { if (occ) housing += (cfg.monthly||0)*12; }
          else if (cfg.type === 'loan') {
            const inRepay = (cfg.repayStart!=null && cfg.repayEnd!=null) ? (age >= cfg.repayStart && age <= cfg.repayEnd) : false;
            if (inRepay) housing += (cfg.resolvedMonthly||0)*12;
            if (occ) housing += (cfg.maintMonthly||0)*12;
          }
        });
        housingData.push(Math.floor(housing));
      }
      const educationData = [];
      const eduConfigMap = new Map((educationConfig || []).map(item => [item.name, item]));
      for (let i=0;i<years;i++){
        let education=0;
        (family.children || []).forEach(child=>{
          const childAge = child.age + i;
          const childEdu = eduConfigMap.get(child.name) || {};
          if (childAge >= 6 && childAge <= 11) education += toNumber(childEdu.elementary);
          else if (childAge >= 12 && childAge <= 14) education += toNumber(childEdu.junior);
          else if (childAge >= 15 && childAge <= 17) education += toNumber(childEdu.high);
          else if (childAge >= 18 && childAge <= 21) education += toNumber(childEdu.university);
          if (childAge >= 0 && childAge <= 21) education += toNumber(childEdu.other);
        });
        educationData.push(Math.floor(education));
      }
      const planData = [];
      for (let i=0;i<years;i++){
        const age = selfAge + i; let plan=0;
        (planConfig||[]).forEach(p=>{
          let shouldPay = false;
          if (p.repeat==='once') shouldPay = (age===p.age);
          else if (p.repeat==='yearly') shouldPay = (age>=p.age && age<=p.endAge);
          else if (p.repeat==='5years') shouldPay = (age>=p.age && age<=p.endAge && (age-p.age)%5===0);
          else if (p.repeat==='10years') shouldPay = (age>=p.age && age<=p.endAge && (age-p.age)%10===0);
          if (shouldPay) plan += p.amount;
        });
        planData.push(Math.floor(plan));
      }
      const assetBalances = (assetConfig||[]).map(cfg => toNumber(cfg.initial, 0));
      const investHistory = []; const cashHistory = []; const annualNetData = [];
      let cashBalance = initialCash;
      for (let i=0;i<years;i++){
        const age = selfAge + i;

        if (age < retireAge) {
            dcBalance *= (1 + dcRate);
            dcBalance += dcAnnualIndivCost + dcAnnualCorpContrib;
        }
        dcData.push(Math.floor(dcBalance));

        let totalPlannedInvestment = 0;
        (assetConfig||[]).forEach((cfg, idx)=>{
          const end = toNumber(cfg.end, 0);
          const meanRate = toNumber(cfg.rate, 0) / 100;
          const stdev = toNumber(cfg.stdev, 15) / 100;
          const takeoutMeanRate = toNumber(cfg.takeoutRate, 0) / 100;
          let calculatedReturn = meanRate;
          let calculatedTakeoutReturn = takeoutMeanRate;
          if (options.useVolatility) {
              calculatedReturn = randn_bm() * stdev + meanRate;
              calculatedTakeoutReturn = randn_bm() * (stdev * 0.5) + takeoutMeanRate; 
          }
          if (age <= end) { 
              const start = toNumber(cfg.start, 0);
              const amount = toNumber(cfg.amount, 0);
              if (age >= start && amount > 0){
                  totalPlannedInvestment += amount;
                  assetBalances[idx] += amount;
              }
             assetBalances[idx] *= (1 + calculatedReturn);
          } else { 
              assetBalances[idx] *= (1 + calculatedTakeoutReturn);
              const takeoutType = cfg.takeoutType || 'lumpSum';
              if (takeoutType === 'lumpSum') {
                  if (age === end + 1 && assetBalances[idx] > 0) {
                      assetTakeouts[i] += assetBalances[idx];
                      assetBalances[idx] = 0;
                  }
              } else if (takeoutType === 'division') {
                  const takeoutAmount = toNumber(cfg.takeoutAmount, 0);
                  if (takeoutAmount > 0 && assetBalances[idx] > 0) {
                      const actualTakeout = Math.min(assetBalances[idx], takeoutAmount);
                      assetTakeouts[i] += actualTakeout;
                      assetBalances[idx] -= actualTakeout;
                  }
              }
          }
        });
        savingData.push(Math.floor(totalPlannedInvestment));
        const income = totalIncome[i] + assetTakeouts[i];
        totalIncome[i] = income; 
        const outflow = livingData[i] + housingData[i] + educationData[i] + planData[i] + taxData[i] + socialSalaryData[i] + pensionSocialData[i] + totalPlannedInvestment + (age < retireAge ? dcAnnualIndivCost : 0);
        const annualNet = income - outflow; annualNetData.push(Math.floor(annualNet));
        cashBalance += annualNet;
        let withdrawn = 0;
        if (cashBalance < 0) {
          const deficit = -cashBalance;
          const totalAssets = assetBalances.reduce((a,b)=>a+b,0);
          if (totalAssets > 0) {
            const cover = Math.min(deficit, totalAssets);
            assetBalances.forEach((bal, idx)=>{
              const share = totalAssets>0 ? (bal/totalAssets)*cover : 0;
              assetBalances[idx] = bal - share;
            });
            cashBalance += cover; withdrawn = cover;
            if (!notifications.some(n => n.type === 'warning' && n.message.includes('資産の取り崩し'))) {
                 notifications.push({ age: age, type: 'warning', message: `⚠️ ${age}歳頃から資産の取り崩しが発生します。` });
            }
          }
        }
        withdrawData.push(Math.floor(withdrawn));
        cashHistory.push(Math.floor(cashBalance));
        investHistory.push(Math.floor(assetBalances.reduce((a,b)=>a+b,0) + dcData[i]));
      }
      const fam = family || {}; const persons = [];
      if (fam.self?.name) persons.push({label:`本人(${fam.self.name})`, baseAge: toNumber(fam.self.age,0)});
      if (fam.spouse?.name) persons.push({label:`配偶者(${fam.spouse.name})`, baseAge: toNumber(fam.spouse.age,0)});
      (fam.children||[]).forEach((c)=>{ if (c?.name) persons.push({label:`子(${c.name})`, baseAge: toNumber(c.age,0)}); });
      if (fam.selfParents?.[0]?.name) persons.push({label:`父(本人)`, baseAge: toNumber(fam.selfParents[0].age,0)});
      if (fam.selfParents?.[1]?.name) persons.push({label:`母(本人)`, baseAge: toNumber(fam.selfParents[1].age,0)});
      if (fam.spouseParents?.[0]?.name) persons.push({label:`父(配偶者)`, baseAge: toNumber(fam.spouseParents[0].age,0)});
      if (fam.spouseParents?.[1]?.name) persons.push({label:`母(配偶者)`, baseAge: toNumber(fam.spouseParents[1].age,0)});
      const familyAgeSeries = [];
      for (let i=0;i<years;i++){ const row = { age: selfAge + i }; persons.forEach(p=> row[p.label] = p.baseAge + i); familyAgeSeries.push(row); }
      const totalPensionData = pensionSelf.map((p, i) => p + (pensionSpouse[i] || 0));
      return {
        years, labels,
        salarySelf, salarySpouse, bonusSelf, bonusSpouse, pensionSelf, totalPensionData, childBenefitData: otherIncome,
        assetTakeouts, notifications,
        totalIncome, taxData, socialSalaryData, pensionSocialData,
        livingData, housingData, educationData, planData,
        savingData, withdrawData,
        annualNetData, cashHistory, investHistory,
        familyAgeSeries, familyPersons: persons,
        dcData,
        meta: { selfName, selfAge, retireAge }
      };
    }
