    function generateTimelineData(params) {
        const timelineData = { '本人': [], '配偶者': [], 'ライフ': [], '住居': [], '資産': [] };
        const selfAge = toNumber(params.family?.self?.age, 30);
        
        (params.family.children || []).forEach(child => {
            const key = `子ども-${child.name}`;
            if(!timelineData[key]) timelineData[key] = [];
        });

        function addEvent(category, startAge, endAge, text, icon = '') {
            if (!timelineData[category] || !startAge) return;
            endAge = endAge || startAge;
            timelineData[category].push({ start: startAge, end: endAge, text, icon });
        }

        const { family, retireAge, retirementBonus, planConfig, housingConfig, assetConfig, spouseIncomeSettings } = params;

        addEvent('本人', retireAge, retireAge, `退職 & 退職金`, '👋');
        if ((family?.spouse?.age || 0) > 0) {
            const spouseRetireAge = spouseIncomeSettings?.retireAge || 65;
            const selfAgeAtSpouseRetire = selfAge + (spouseRetireAge - family.spouse.age);
            addEvent('配偶者', selfAgeAtSpouseRetire, selfAgeAtSpouseRetire, '退職', '👋');
        }
        
        (family.children || []).forEach(child => {
            const key = `子ども-${child.name}`;
            const birthAge = selfAge - child.age;
            addEvent(key, birthAge, birthAge, `${child.name} 誕生`, '👶');
            addEvent(key, birthAge + 6, birthAge + 6, `小学校入学`, '🎒');
            addEvent(key, birthAge + 12, birthAge + 12, `中学校入学`, '🧑‍🏫');
