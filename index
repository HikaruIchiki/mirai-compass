      const existing = safeJSONParse(document.getElementById(getCustomIncomeStoreKey(target)).value, []);
      const map = new Map(existing.map(e=>[e.age, e.salary])); const g = growthPct/100;
      for (let i=0;i<years;i++){
        const age = baseAge + i;
        if (age > retireAge) break;
        const base = (age <= retireAge) ? Math.floor(startIncome * Math.pow(1+g, i)) : '';
