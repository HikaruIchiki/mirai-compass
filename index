    function detectAndFill(target, keepFilled=true){
      const emptyToZero = document.getElementById('incomeEmptyToZero')?.checked;
      const inputs = Array.from(document.querySelectorAll('#incomeCustomBody input'));
      if (emptyToZero) { inputs.forEach(inp=>{ if (inp.value === '') inp.value = '0'; }); return; }
      const points = [];
      inputs.forEach(inp=>{
        if (inp.value === '0') return;
        const age = parseInt(inp.dataset.age,10);
        const val = toNumber(inp.value, NaN);
        if (Number.isFinite(val) && val>0) points.push({age, y: val});
      });
      if (points.length < 2) {
        const { baseAge, startIncome, growthPct } = baseIncomeParams(target);
        const g = growthPct/100;
        inputs.forEach(inp=>{
          if (inp.value !== '') return;
          const t = parseInt(inp.dataset.age,10) - baseAge;
          inp.value = Math.round(startIncome * Math.pow(1+g, t));
        });
        return;
      }
      const minAge = Math.min(...points.map(p=>p.age));
      const xs = points.map(p=>p.age - minAge);
      const ys = points.map(p=>Math.log(p.y));
      const n = xs.length;
      const sumX = xs.reduce((a,b)=>a+b,0);
      const sumY = ys.reduce((a,b)=>a+b,0);
      const sumXX = xs.reduce((a,b)=>a+b*b,0);
      const sumXY = xs.reduce((a,xi,i)=>a+xi*ys[i],0);
      const denom = (n*sumXX - sumX*sumX) || 1;
      const slope = (n*sumXY - sumX*sumY)/denom;
      const intercept = (sumY - slope*sumX)/n;
      const r = Math.exp(slope) - 1;
      const rAdj = Math.max(-0.05, Math.min(0.08, 0.8*r));
      inputs.forEach(inp=>{
        if (inp.value === '0') return;
        if (keepFilled && inp.value !== '') return;
        const age = parseInt(inp.dataset.age,10);
        const t = age - minAge;
        const y = Math.exp(intercept + Math.log(1+rAdj)*t);
        inp.value = Math.round(y);
      });
    }
