  <script>
    // --- Safe JSON Parser ---
    function safeJSONParse(str, defaultVal) {
        try {
            return str ? JSON.parse(str) : defaultVal;
        } catch (e) {
            console.warn("JSON Parse Error:", e);
            return defaultVal;
        }
    }

    // --- NEW: Mode Selection and Tab Logic ---
    document.addEventListener('DOMContentLoaded', () => {
        const modeModal = document.getElementById('mode-selection-modal');
        const sampleAccordionHeader = document.querySelector('.accordion-header[data-section="sample"]');
        const sampleAccordionContent = sampleAccordionHeader.nextElementSibling;
        
        // かんたんシミュレーション
        document.getElementById('easy-sim-btn').addEventListener('click', () => {
            modeModal.style.display = 'none'; // Use style.display to hide instead of remove class for persistence
            document.getElementById('assistModal').classList.add('show');
        });

        // 詳細シミュレーション
        document.getElementById('detailed-sim-btn').addEventListener('click', () => {
            modeModal.style.display = 'none';
        });
        
        // サンプルデータ
        document.getElementById('sample-data-mode-btn').addEventListener('click', () => {
            modeModal.style.display = 'none';
            // Open accordion if not already open
            if (!sampleAccordionHeader.classList.contains('active')) {
                sampleAccordionHeader.classList.add('active');
                sampleAccordionContent.classList.add('active');
            }
            sampleAccordionHeader.scrollIntoView({ behavior: 'smooth' });
        });

        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                tabButtons.forEach(btn => btn.classList.remove('active'));
                button.classList.add('active');

                const targetTab = button.dataset.tab;
                tabContents.forEach(content => {
                    if (content.id === targetTab) {
                        content.classList.add('active');
                    } else {
                        content.classList.remove('active');
                    }
                });
            });
        });
    });


    // --- Original Script (with minor adjustments) ---
    const fmt = new Intl.NumberFormat('ja-JP',{maximumFractionDigits:0});
    function formatAmount(v){ return fmt.format(Math.floor(v)); }
    function toNumber(val, def=0){ const n=parseFloat(val); return Number.isFinite(n)?n:def; }
    function calcProgressiveTax(amount){
      const b=[{l:195,r:0.05},{l:330,r:0.1},{l:695,r:0.2},{l:900,r:0.23},{l:1800,r:0.33},{l:4000,r:0.4},{l:Infinity,r:0.45}];
      let tax=0,prev=0;
      for(const br of b){
        if(amount>br.l){ tax+=(br.l-prev)*br.r; prev=br.l; }
        else{ tax+=(amount-prev)*br.r; break; }
      }
      return Math.floor(tax);
    }
    function calcSalaryTaxAndSocial(salaryPlusBonusManYen){
      const tax = calcProgressiveTax(salaryPlusBonusManYen);
      const social = Math.floor(salaryPlusBonusManYen * 0.15);
      return { tax, social };
    }
    function calcPensionTaxAndSocial(pensionManYen){
      const deduction = 120;
      const taxable = Math.max(0, pensionManYen - deduction);
      const tax = calcProgressiveTax(taxable);
      const social = Math.floor(pensionManYen * 0.10);
      return { tax, social };
    }
    function calcLoanMonthly(principal, annualRate, years) {
      if (principal <= 0 || years <= 0) return 0;
      const monthlyRate = annualRate / 100 / 12;
      const n = years * 12;
      if (monthlyRate === 0) return principal / n;
      return principal * monthlyRate * Math.pow(1 + monthlyRate, n) / (Math.pow(1 + monthlyRate, n) - 1);
    }
    // 正規分布（平均0, 標準偏差1）の乱数を生成 (Box-Muller法)
    function randn_bm() {
        let u = 0, v = 0;
        while(u === 0) u = Math.random(); // 0を除く
        while(v === 0) v = Math.random();
        return Math.sqrt( -2.0 * Math.log( u ) ) * Math.cos( 2.0 * Math.PI * v );
    }
    function calculateSurvivorsPension(params, deathAge, pensionTermYears, currentYearIndex) {
        const selfAge = toNumber(params.family.self?.age, 30);
        let totalPension = 0;
        const KOSEI_NENKIN_RATE = 5.481 / 1000;
        const avgMonthlySalary = params.pensionConfig.selfAvgMonthly || 0;
        const pensionMonths = Math.max(300, pensionTermYears * 12); 
        const oldAgePensionPortion = avgMonthlySalary * KOSEI_NENKIN_RATE * pensionMonths;
        const survivorsEmployeesPension = oldAgePensionPortion * 0.75;
        totalPension += survivorsEmployeesPension;
        const children = params.family.children || [];
        const deathYearSimIndex = deathAge - selfAge;
        const spouseAgeAtDeath = (params.family.spouse?.age || 0) + deathYearSimIndex;
        const spouseCurrentAge = spouseAgeAtDeath + (currentYearIndex - deathYearSimIndex);
        const eligibleChildren = children.map(c => c.age + currentYearIndex).filter(age => age >= 0 && age < 18);
        if (eligibleChildren.length > 0) {
            let basicPension = 81.6; 
            if (eligibleChildren.length >= 1) basicPension += 23.48;
            if (eligibleChildren.length >= 2) basicPension += 23.48;
            if (eligibleChildren.length >= 3) {
                basicPension += (eligibleChildren.length - 2) * 7.83;
            }
            totalPension += basicPension;
        } else {
            if ((params.family.spouse?.age || 0) > 0 && spouseCurrentAge >= 40 && spouseCurrentAge < 65) {
                totalPension += 61.2;
            }
        }
        return totalPension;
    }
    document.querySelectorAll('.accordion-header').forEach(header => {
      header.addEventListener('click', () => {
        const content = header.nextElementSibling;
        const isActive = header.classList.contains('active');
        if (isActive) { header.classList.remove('active'); content.classList.remove('active'); }
        else { header.classList.add('active'); content.classList.add('active'); }
      });
    });
    const sampleData = {
      single: {
