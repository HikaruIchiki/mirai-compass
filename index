                const MONTE_CARLO_RUNS = 1000;
                let failureCount = 0;
                const finalAssetsMonte = [];
                let maxDeficitMonte = 0;
                let firstDeficitAgeMonteSum = 0;
                let deficitCaseCount = 0;

                for (let i = 0; i < MONTE_CARLO_RUNS; i++) {
                    const sim = runSimulation(originalParams, { useVolatility: true }); 
                    if (!sim) continue;
                    
                    const finalAsset = (sim.cashHistory.at(-1) || 0) + (sim.investHistory.at(-1) || 0);
