    function runSimulation(params, options = { useVolatility: false }){
      const {
        selfName, incomeStart, incomeGrowthPct, retireAge, retirementBonus, livingMonthly,
        inflationPct, initialCash, assetConfig, housingConfig, planConfig, educationConfig,
        customIncomeSelf, customIncomeSpouse, family, spouseIncomeSettings, pensionConfig, dcConfig
      } = params;
