                        if (sim.cashHistory[j] < 0) {
                            simFailed = true;
                            if(firstDeficitAge === -1) firstDeficitAge = (originalParams.family?.self?.age || 30) + j;
                            maxDeficitMonte = Math.min(maxDeficitMonte, sim.cashHistory[j]);
                        }
                    }
                    if (simFailed) {
                        failureCount++;
                        if (firstDeficitAge !== -1) {
                            firstDeficitAgeMonteSum += firstDeficitAge;
                            deficitCaseCount++;
                        }
                    }
                }

                finalAssetsMonte.sort((a, b) => a - b);
                const medianAssets = finalAssetsMonte[Math.floor(MONTE_CARLO_RUNS / 2)];
                const lower10Assets = finalAssetsMonte[Math.floor(MONTE_CARLO_RUNS * 0.1)];
                const failureRate = (failureCount / MONTE_CARLO_RUNS) * 100;
                const avgDeficitAge = deficitCaseCount > 0 ? (firstDeficitAgeMonteSum / deficitCaseCount).toFixed(0) : '-';

                if (failureRate > 0) {
                    reportHTML += `<p style="color:red; font-weight:bold;">
