    function updateLoanMonthlyDisplay(row){
      const disp = row.querySelector('.loan-monthly-display');
      if (!disp || disp.classList.contains('hidden')) return;
      const repayStart = toNumber(row.querySelector('input[data-type="repayStart"]')?.value, NaN);
      const repayEnd = toNumber(row.querySelector('input[data-type="repayEnd"]')?.value, NaN);
      const principal = toNumber(row.dataset.principal, 0);
      const rate = toNumber(row.dataset.rate, 0);
      const bonusAdd = toNumber(row.dataset.bonusAdd, 0);
      if (!Number.isFinite(repayStart) || !Number.isFinite(repayEnd) || repayEnd < repayStart || principal<=0) { disp.textContent='-'; return; }
      const years = Math.max(1, repayEnd - repayStart + 1);
      const m = calcLoanMonthly(principal, rate, years) + (bonusAdd>0 ? bonusAdd/12 : 0);
      disp.textContent = `${formatAmount(m)} 万円/月`;
    }
